---
// A single service card (used on the homepage services grid).
// Industrial "spec panel": hairline border, mono-style index, terracotta
// tick on hover.
interface Props {
  index: number;
  title: string;
  description: string;
}
const { index, title, description } = Astro.props;
const num = String(index).padStart(2, '0');
---

<article class="reveal group flex h-full flex-col panel p-7 transition-colors duration-300 hover:border-terracotta/50">
  <div class="flex items-center justify-between">
    <span class="text-xs font-semibold tracking-[0.15em] text-gold">{num}</span>
    <span class="h-2 w-2 bg-terracotta opacity-0 transition-opacity duration-300 group-hover:opacity-100"></span>
  </div>
  <h3 class="mt-5 text-h3 font-medium text-charcoal">{title}</h3>
  <p class="mt-3 text-[0.95rem] leading-relaxed text-charcoal/70">{description}</p>
</article>
