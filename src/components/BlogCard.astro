---
// A blog-post preview card (homepage Insights + Blog index).
import Figure from './Figure.astro';

interface Props {
  href: string;
  image: string;
  imageAlt: string;
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
}
const { href, image, imageAlt, title, description, pubDate, tags } = Astro.props;

// Human-readable date, e.g. "June 18, 2026"
const dateLabel = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const dateISO = pubDate.toISOString().split('T')[0];
---

<article class="reveal group">
  <a href={href} class="block">
    <Figure src={image} alt={imageAlt} ratio="16/10" widths={[400, 800, 1200]} sizes="(min-width: 768px) 33vw, 100vw" class="transition-transform duration-500 group-hover:scale-[1.015]" />
    {tags && tags.length ? (
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full border border-charcoal/10 bg-stone px-3 py-1 text-[0.72rem] uppercase tracking-[0.24em] text-charcoal/70">
            {tag}
          </span>
        ))}
      </div>
    ) : null}
    <div class="mt-5">
      <time datetime={dateISO} class="text-xs uppercase tracking-label text-charcoal/50">
        {dateLabel}
      </time>
      <h3 class="mt-3 text-h3 font-semibold text-charcoal transition-colors group-hover:text-terracotta">
        {title}
      </h3>
      <p class="mt-2 text-[0.95rem] leading-relaxed text-charcoal/70">{description}</p>
    </div>
  </a>
</article>
