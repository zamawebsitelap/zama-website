---
// ===================================================================
//  FOOTER — the dark, high-contrast closing section.
//  Nav, socials, and contact all come from
//  src/config/site.ts. Edit that file to change them.
// ===================================================================
import { site, nav, socials } from '../config/site';

const year = new Date().getFullYear();
const emailHref = `https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(site.email)}`;
---

<footer class="bg-ink text-cream/80">
  <div class="container py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr] md:gap-8">
      {/* Brand + tagline */}
      <div>
        <p class="font-serif text-3xl font-semibold text-cream">{site.name}</p>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-cream/70">
          {site.tagline} A boutique digital marketing agency in {site.location.city}, {site.location.region}.
        </p>
        <a
          href={emailHref}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-block text-sm text-cream underline decoration-gold/60 underline-offset-4 transition-colors hover:text-gold"
        >
          {site.email}
        </a>
        {site.phone && (
          <p class="mt-3 text-sm text-cream/70">{site.phone}</p>
        )}
      </div>

      {/* Explore (main nav) */}
      <nav aria-label="Footer">
        <p class="label text-gold">Explore</p>
        <ul class="mt-4 space-y-2.5">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-cream/75 transition-colors hover:text-cream"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {/* Connect (socials) */}
      <div>
        <p class="label text-gold">Connect</p>
        <ul class="mt-4 space-y-2.5">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  rel="noopener noreferrer"
                  target="_blank"
                  class="text-sm text-cream/75 transition-colors hover:text-cream"
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <hr class="mt-14 border-0 border-t border-white/10" />

    <div class="mt-6 text-xs text-cream/55">
      <p>© {year} {site.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
