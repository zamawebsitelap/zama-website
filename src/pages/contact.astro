---
// ===================================================================
//  CONTACT PAGE
//  Copy + form fields: src/content/pages/contact.yml
//  NOTE: the form is front-end only (it shows a success message but
//  does not send email yet). See the README section "Making the
//  contact form send email" to connect it to a service like Formspree.
// ===================================================================
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Figure from '../components/Figure.astro';
import { site, socials } from '../config/site';

const page = await getEntry('pages', 'contact');
const c = page.data as any;
const fields = c.form.fields as Array<{
  name: string;
  label: string;
  type: string;
  required: boolean;
}>;

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path: '/contact' },
];
const emailHref = `https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(site.email)}`;
---

<BaseLayout title={c.seo.title} description={c.seo.description} breadcrumbs={breadcrumbs}>
  <section class="container py-16 md:py-24">
    <div class="grid gap-14 md:grid-cols-[1fr_1.1fr] md:gap-20">
      {/* ---- Left: intro + alternate contact ---- */}
      <div>
        <p class="label">{c.label}</p>
        <h1 class="mt-4 text-h1 font-semibold text-charcoal">{c.h1}</h1>
        <p class="mt-6 max-w-md text-lead text-charcoal/75">{c.intro}</p>

        <div class="mt-10 border-t border-gold/30 pt-8">
          <p class="text-charcoal/80">
            {c.altContactText}{' '}
            <a
              href={emailHref}
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-terracotta underline decoration-gold/50 underline-offset-4 hover:text-terracotta-deep"
            >
              {site.email}
            </a>
            {site.phone && (
              <span>
                {' '}or call us at <a href={`tel:${site.phone}`} class="font-medium text-terracotta underline decoration-gold/50 underline-offset-4 hover:text-terracotta-deep">{site.phone}</a>
              </span>
            )}
          </p>
          <ul class="mt-6 flex gap-5">
            {
              socials.map((s) => (
                <li>
                  <a
                    href={s.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm font-medium text-charcoal underline decoration-gold/50 underline-offset-4 transition-colors hover:text-terracotta"
                  >
                    {s.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        {/* Photo (swap in /public/images/ - see contact.yml) */}
        <div class="mt-10 hidden md:block">
          <Figure src={c.image} alt={c.imageAlt} ratio="9/16" />
        </div>
      </div>

      {/* ---- Right: contact form ---- */}
      <div class="rounded-3xl border border-gold/25 bg-white p-7 md:p-10">
        <form
          id="contact-form"
          name="contact"
          method="POST"
          action="/contact?success=1"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6"
        >
          {/* Netlify Forms: identifies which form was submitted */}
          <input type="hidden" name="form-name" value="contact" />
          {/* Honeypot field — hidden from people, catches spam bots */}
          <p class="hidden" aria-hidden="true">
            <label>
              Don't fill this out if you're human: <input name="bot-field" />
            </label>
          </p>
          {
            fields.map((f) => (
              <div>
                <label for={f.name} class="block text-sm font-medium text-charcoal">
                  {f.label}
                  {f.required && <span class="text-terracotta" aria-hidden="true"> *</span>}
                </label>
                {f.type === 'textarea' ? (
                  <textarea
                    id={f.name}
                    name={f.name}
                    rows="5"
                    required={f.required}
                    class="mt-2 w-full rounded-xl border border-charcoal/15 bg-cream/50 px-4 py-3 text-charcoal outline-none transition-colors placeholder:text-charcoal/40 focus:border-terracotta focus:bg-white"
                  />
                ) : (
                  <input
                    id={f.name}
                    name={f.name}
                    type={f.type}
                    required={f.required}
                    autocomplete={f.type === 'email' ? 'email' : 'on'}
                    class="mt-2 w-full rounded-xl border border-charcoal/15 bg-cream/50 px-4 py-3 text-charcoal outline-none transition-colors placeholder:text-charcoal/40 focus:border-terracotta focus:bg-white"
                  />
                )}
              </div>
            ))
          }

          <button type="submit" class="btn-primary w-full">{c.form.submitLabel}</button>

          {/* Success message (revealed after Netlify redirects back with ?success=1) */}
          <p
            id="form-success"
            role="status"
            class="hidden rounded-xl bg-terracotta/10 px-4 py-3 text-sm text-terracotta-deep"
          >
            {c.form.successMessage}
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // The form posts to Netlify Forms, which redirects back here with
  // ?success=1 — reveal the confirmation message when it does.
  (function () {
    if (new URLSearchParams(window.location.search).get('success') !== '1') return;
    const success = document.getElementById('form-success');
    if (!success) return;
    success.classList.remove('hidden');
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
  })();
</script>
