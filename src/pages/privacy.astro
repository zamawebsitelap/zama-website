---
// ===================================================================
//  PRIVACY POLICY (placeholder)
//  Replace the placeholder text below with your real privacy policy.
//  A lawyer or a policy generator can help you produce the final copy.
// ===================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Privacy Policy', path: '/privacy' },
];
---

<BaseLayout
  title="Privacy Policy | ZAMA"
  description="How ZAMA collects, uses, and protects your information."
  breadcrumbs={breadcrumbs}
  noindex={true}
>
  <section class="container py-16 md:py-24">
    <div class="mx-auto max-w-prose">
      <h1 class="text-h1 font-semibold text-charcoal">Privacy Policy</h1>
      <div class="prose-zama mt-8 space-y-5 text-[1.05rem] leading-relaxed text-charcoal/80">
        <p>
          <em
            >This is placeholder text. Replace it with your real privacy policy
            before launch — edit <code>src/pages/privacy.astro</code>.</em
          >
        </p>
        <p>
          ZAMA respects your privacy. This page will describe what information we
          collect, how we use it, and the choices you have. If you have any
          questions, contact us at
          <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
