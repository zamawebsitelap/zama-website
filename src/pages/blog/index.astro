---
// ===================================================================
//  BLOG INDEX
//  Copy: src/content/pages/blog.yml
//  Posts: src/content/blog/*.md
// ===================================================================
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const page = await getEntry('pages', 'blog');
const c = page.data as any;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
];
---

<BaseLayout title={c.seo.title} description={c.seo.description} breadcrumbs={breadcrumbs}>
  <section class="container pb-8 pt-16 md:pt-24">
    <div class="max-w-3xl">
      <p class="label">{c.label}</p>
      <h1 class="mt-4 text-h1 font-semibold text-charcoal">{c.h1}</h1>
      <p class="mt-6 text-lead text-charcoal/75">{c.intro}</p>
    </div>
  </section>

  <section class="container py-section">
    <div class="grid gap-x-8 gap-y-14 md:grid-cols-3">
      {
        posts.map((p) => (
          <BlogCard
            href={`/blog/${p.slug}`}
            image={p.data.image}
            imageAlt={p.data.imageAlt}
            title={p.data.title}
            description={p.data.description}
            pubDate={p.data.pubDate}
            tags={p.data.tags}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
