---
// ===================================================================
//  ABOUT PAGE
//  Copy: src/content/pages/about.yml
// ===================================================================
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Figure from '../components/Figure.astro';

const page = await getEntry('pages', 'about');
const c = page.data as any;

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about' },
];
---

<BaseLayout
  title={c.seo.title}
  description={c.seo.description}
  keywords={c.seo.keywords}
  breadcrumbs={breadcrumbs}
>
  {/* ---- Intro ---- */}
  <section class="container pb-8 pt-16 md:pt-24">
    <div class="max-w-3xl">
      <p class="label">{c.label}</p>
      <h1 class="mt-4 text-h1 font-semibold text-charcoal">{c.h1}</h1>
    </div>
  </section>

  {/* ---- Story + image ---- */}
  <section class="container py-section">
    <div class="grid items-start gap-12 md:grid-cols-2 md:gap-16">
      <div class="reveal">
        <Figure src={c.image} alt={c.imageAlt} ratio="4/5" />
      </div>
      <div class="space-y-5 md:pt-4">
        {
          c.story.map((para: string) => (
            <p class="max-w-prose text-[1.08rem] leading-relaxed text-charcoal/80 reveal">{para}</p>
          ))
        }
      </div>
    </div>
  </section>

  {/* ---- Values ---- */}
  <section class="bg-stone">
    <div class="container py-section">
      <div class="max-w-2xl">
        <p class="label">{c.valuesLabel}</p>
        <h2 class="mt-4 text-h2 font-semibold text-charcoal">{c.valuesHeading}</h2>
      </div>
      <div class="mt-14 grid gap-x-10 gap-y-10 sm:grid-cols-2">
        {
          c.values.map((v: any) => (
            <div class="reveal border-t border-gold/30 pt-6">
              <h3 class="font-serif text-h3 font-semibold text-charcoal">{v.title}</h3>
              <p class="mt-2 max-w-md text-[0.98rem] leading-relaxed text-charcoal/70">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* ---- Why ZAMA (dark section) ---- */}
  <section class="bg-ink">
    <div class="container grid gap-12 py-section md:grid-cols-[0.8fr_1.2fr] md:gap-16">
      <div>
        <p class="label text-gold">{c.whyLabel}</p>
        <h2 class="mt-4 text-h2 font-semibold text-cream">{c.whyHeading}</h2>
      </div>
      <ul class="space-y-5">
        {
          c.why.map((item: string) => (
            <li class="reveal flex gap-4 border-b border-white/10 pb-5 text-lead text-cream/85">
              <span aria-hidden="true" class="mt-1 text-gold">&mdash;</span>
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ---- Closing CTA ---- */}
  <section class="bg-terracotta">
    <div class="container py-section text-center">
      <a href={c.cta.button.href} class="reveal inline-block">
        <span class="font-serif text-h1 font-semibold text-cream underline decoration-cream/40 decoration-1 underline-offset-8 transition-colors hover:decoration-cream">
          {c.cta.button.label}
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
