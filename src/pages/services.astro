---
// ===================================================================
//  SERVICES PAGE
//  Copy: src/content/pages/services.yml
//  Service descriptions: src/content/services/*.yml
// ===================================================================
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const page = await getEntry('pages', 'services');
const c = page.data as any;

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Services', path: '/services' },
];
---

<BaseLayout
  title={c.seo.title}
  description={c.seo.description}
  keywords={c.seo.keywords}
  breadcrumbs={breadcrumbs}
>
  {/* ---- Page intro ---- */}
  <section class="container pb-8 pt-16 md:pt-24">
    <div class="max-w-3xl">
      <p class="label">{c.label}</p>
      <h1 class="mt-4 text-h1 font-semibold text-charcoal">{c.h1}</h1>
      <p class="mt-6 text-lead text-charcoal/75">{c.intro}</p>
    </div>
  </section>

  {/* ---- Services list (numbered, editorial rows) ---- */}
  <section class="container py-section">
    <div class="border-t border-gold/25">
      {
        services.map((s, i) => (
          <article class="reveal grid gap-4 border-b border-gold/25 py-10 md:grid-cols-[auto_1fr] md:gap-12 md:py-12">
            <div class="flex items-baseline gap-5 md:block">
              <span class="font-serif text-3xl text-gold/70">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            <div class="md:grid md:grid-cols-[0.9fr_1.1fr] md:gap-12">
              <h2 class="text-h3 font-semibold text-charcoal">{s.data.title}</h2>
              <p class="mt-3 max-w-prose text-[1.02rem] leading-relaxed text-charcoal/75 md:mt-0">
                {s.data.long}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  {/* ---- Closing CTA ---- */}
  <section class="bg-ink">
    <div class="container flex flex-col items-center gap-6 py-section text-center md:flex-row md:justify-between md:text-left">
      <p class="text-h2 font-serif font-medium text-cream reveal">{c.cta.text}</p>
      <a href={c.cta.button.href} class="btn-on-dark reveal">{c.cta.button.label}</a>
    </div>
  </section>
</BaseLayout>
