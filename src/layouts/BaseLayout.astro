---
// ===================================================================
//  BASE LAYOUT
//  The HTML shell shared by every page: <head> (fonts, SEO, structured
//  data), the sticky Header, the page content (<slot />), and the
//  Footer. You rarely need to edit this file.
// ===================================================================
import '../styles/global.css';

// --- Self-hosted fonts (no render-blocking third-party requests) ---
// Cormorant Garamond: headlines/display, incl. italics for the hero.
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/600.css';
import '@fontsource/cormorant-garamond/700.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource/cormorant-garamond/500-italic.css';
import '@fontsource/cormorant-garamond/600-italic.css';
// Hanken Grotesk: body, UI, buttons, labels.
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/500.css';
import '@fontsource/hanken-grotesk/600.css';
import '@fontsource/hanken-grotesk/700.css';

import SEO from '../components/SEO.astro';
import StructuredData from '../components/StructuredData.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../config/site';

interface Crumb { name: string; path: string; }
interface Faq { question: string; answer: string; }

interface Article {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  image?: string;
  imageAlt?: string;
}

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  breadcrumbs?: Crumb[];
  faqs?: Faq[];
  /** Pass on blog posts: adds BlogPosting schema + article meta tags. */
  article?: Article;
}

const {
  title,
  description,
  keywords,
  image,
  imageAlt,
  type = 'website',
  noindex = false,
  breadcrumbs = [],
  faqs = [],
  article,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#FBF8F3" />

    {/* RSS autodiscovery (browsers, readers & crawlers find the feed) */}
    <link rel="alternate" type="application/rss+xml" title={`${site.name} — Insights`} href="/rss.xml" />

    {/* SEO meta + social cards */}
    <SEO
      title={title}
      description={description}
      keywords={keywords}
      image={image}
      imageAlt={imageAlt}
      type={type}
      noindex={noindex}
      publishedTime={article?.pubDate}
    />

    {/* Structured data (Organization, WebSite, ProfessionalService/LocalBusiness, + optional Breadcrumbs, FAQ & BlogPosting) */}
    <StructuredData breadcrumbs={breadcrumbs} faqs={faqs} article={article} />

    {/* Google Analytics (GA4) — only in production builds */}
    {
      import.meta.env.PROD && (
        <>
          <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-8L0SZWFS3J"></script>
          <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-8L0SZWFS3J');
          </script>
        </>
      )
    }
  </head>

  <body>
    {/* Skip link for keyboard & screen-reader users */}
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-charcoal focus:px-5 focus:py-3 focus:text-cream"
    >
      Skip to content
    </a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    {/* --- Subtle scroll-reveal (progressive enhancement, respects reduced motion) --- */}
    <script is:inline>
      (function () {
        const els = document.querySelectorAll('.reveal');
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-visible'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>
  </body>
</html>
